diff --git a/drivers/phy/phy-airoha-pcie.c b/drivers/phy/phy-airoha-pcie.c
index 56e9ade8a9fd..d30236099faf 100644
--- a/drivers/phy/phy-airoha-pcie.c
+++ b/drivers/phy/phy-airoha-pcie.c
@@ -106,6 +106,7 @@ airoha_phy_init_lane0_rx_fw_pre_calib(struct airoha_pcie_phy *pcie_phy,
 	u32 fl_out_target = gen == PCIE_PORT_GEN3 ? 41600 : 41941;
 	u32 lock_cyclecnt = gen == PCIE_PORT_GEN3 ? 26000 : 32767;
 	u32 pr_idac, val, cdr_pr_idac_tmp = 0;
+	u32 fl_out;
 	int i;
 
 	airoha_phy_pma0_set_bits(pcie_phy,
@@ -205,6 +206,7 @@ airoha_phy_init_lane0_rx_fw_pre_calib(struct airoha_pcie_phy *pcie_phy,
 		cdr_pr_idac_tmp = pr_idac;
 	}
 
+	fl_out = val;
 	airoha_phy_pma0_update_field(pcie_phy,
