@@ -387,6 +395,10 @@ airoha_phy_init_lane1_rx_fw_pre_calib(struct airoha_pcie_phy *pcie_phy,
 			break;
 	}
 
+	if (!(val & PCIE_RO_FBCK_LOCK))
+		pr_err("FAILED TO LOCK idac: %x fl_out: %d fl_out_target: %d\n",
+		       cdr_pr_idac_tmp, fl_out, fl_out_target);
+
 	/* turn off force mode and update band values */
 	airoha_phy_csr_2l_clear_bits(pcie_phy, REG_CSR_2L_CDR1_PR_INJ_MODE,
 				     CSR_2L_PXP_CDR1_INJ_FORCE_OFF);
