From ad21764ed528669f72699c2a9f7e999d1d29e583 Mon Sep 17 00:00:00 2001
From: Aleksander Jan Bajkowski <olek2@wp.pl>
Date: Sun, 31 Aug 2025 22:38:00 +0200
Subject: [PATCH] test

---
 drivers/net/mdio/mdio-i2c.c | 16 +++++++++++++---
 drivers/net/phy/sfp.c       |  3 ++-
 2 files changed, 15 insertions(+), 4 deletions(-)

diff --git a/drivers/net/mdio/mdio-i2c.c b/drivers/net/mdio/mdio-i2c.c
index ed20352a589a..ebf9f7e52a3a 100644
--- a/drivers/net/mdio/mdio-i2c.c
+++ b/drivers/net/mdio/mdio-i2c.c
@@ -318,18 +318,21 @@ static int i2c_rollball_mii_poll(struct mii_bus *bus, int bus_addr, u8 *buf,
 	/* By experiment it takes up to 70 ms to access a register for these
 	 * SFPs. Sleep 20ms between iterations and try 10 times.
 	 */
-	i = 10;
+	i = 200;
 	do {
-		msleep(20);
+		msleep(1);
 
 		ret = i2c_transfer_rollball(i2c, msgs, ARRAY_SIZE(msgs));
 		if (ret)
 			return ret;
 
-		if (*res == ROLLBALL_CMD_DONE)
+		if (*res == ROLLBALL_CMD_DONE) {
+			printk(KERN_ERR "%s:1 time=%d\n", __func__, 200 - i);
 			return 0;
+		}
 	} while (i-- > 0);
 
+	printk(KERN_ERR "%s:2 timeout\n", __func__);
 	dev_dbg(&bus->dev, "poll timed out\n");
 
 	return -ETIMEDOUT;
@@ -365,6 +368,10 @@ static int i2c_mii_read_rollball(struct mii_bus *bus, int phy_id, int devad,
 	int bus_addr, ret;
 	u16 val;
 
+	msleep(25);
+
+	printk(KERN_ERR "%s:1 read: phy_id=%d, devadd=%02x, reg=%04x\n", __func__, phy_id, devad, reg);
+
 	bus_addr = i2c_mii_phy_addr(phy_id);
 	if (bus_addr != ROLLBALL_PHY_I2C_ADDR)
 		return 0xffff;
@@ -387,6 +394,7 @@ static int i2c_mii_read_rollball(struct mii_bus *bus, int phy_id, int devad,
 
 	val = res[4] << 8 | res[5];
 
+	printk(KERN_ERR "%s:2 data=%04x\n", __func__, val);
 	return val;
 }
 
@@ -396,6 +404,8 @@ static int i2c_mii_write_rollball(struct mii_bus *bus, int phy_id, int devad,
 	int bus_addr, ret;
 	u8 buf[6];
 
+	msleep(25);
+
 	bus_addr = i2c_mii_phy_addr(phy_id);
 	if (bus_addr != ROLLBALL_PHY_I2C_ADDR)
 		return 0;
diff --git a/drivers/net/phy/sfp.c b/drivers/net/phy/sfp.c
index bac30afe6b61..419667385975 100644
--- a/drivers/net/phy/sfp.c
+++ b/drivers/net/phy/sfp.c
@@ -411,7 +411,8 @@ static void sfp_fixup_rollball_wait4s(struct sfp *sfp)
 	 * them does not return 0xffff for PHY ID registers in all MMDs for the
 	 * while initializing. They need a 4 second wait before accessing PHY.
 	 */
-	sfp->module_t_wait = msecs_to_jiffies(4000);
+	sfp->module_t_start_up = msecs_to_jiffies(60000);
+	sfp->module_t_wait = msecs_to_jiffies(60000);
 }
 
 static void sfp_fixup_fs_10gt(struct sfp *sfp)
-- 
